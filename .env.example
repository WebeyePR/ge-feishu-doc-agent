# --- 飞书 (Lark) 集成配置 ---
# （必填参数）注册 Agent Engine 到 Gemini Enterprise 时设置的 auth_id (唯一资源标识符，自定义)
LARK_AUTH_ID="your-unique-auth-id"  # 如 lark-agent-oauth-id
# （必填参数）飞书开放平台应用 App ID
LARK_CLIENT_ID="your-lark-app-id"
# （必填参数）飞书开放平台应用 App Secret
LARK_CLIENT_SECRET="your-lark-app-secret"

# 飞书开放平台域名
LARK_DOMAIN="https://open.feishu.cn"
# 飞书授权URI
LARK_AUTHORIZATION_URI="https://accounts.feishu.cn/open-apis/authen/v1/authorize?client_id=cli_a9b3af98cdf9dcef&response_type=code&scope=bitable:app%20docs:document:import%20docx:document%20drive:drive%20drive:drive.metadata:readonly%20drive:drive.search:readonly%20drive:drive:readonly%20wiki:wiki%20wiki:wiki:readonly%20docs:document.content:read%20docs:document:export%20docs:permission.setting:read%20drive:export:readonly%20offline_access%20search:docs:read%20docx:document%20docx:document:readonly%20docs:document.media:download"
# 飞书令牌URI
LARK_TOKEN_URI="https://open.feishu.cn/open-apis/authen/v2/oauth/token"


# --- Google Cloud Platform (Vertex AI) 配置 ---
# （必填参数）GCP 项目 ID (Vertex AI 调用及部署时需要)
PROJECT_ID=""  # your-project-id
# （选填）API 服务区域 (如 us-central1，全局为 global)
LOCATION="global"
# （选填）目标 Gemini 模型名称 (如 gemini-3-flash-preview)
MODEL_NAME="gemini-3-flash-preview"


# --- Google Cloud 部署配置 ---
# （选填）Reasoning Engine 的部署区域 (如 us-central1)
DEPLOY_LOCATION="us-central1"
# （选填）用于存放部署文件的 Google Cloud Storage Bucket 地址
STAGING_BUCKET="gs://adk-agent-deploy"
# （选填）Agent 显示名称
AGENT_DISPLAY_NAME="Lark Document Agent"
# （选填）Agent 描述信息
AGENT_DESCRIPTION="A helpful assistant for Lark documents"


# --- Gemini Enterprise 配置，查看App: https://console.cloud.google.com/gemini-enterprise/apps ---
# （必填参数）Gemini Enterprise 中对应的 App (Engine) ID
GE_APP_ID=""  # 如 webeye-app_1742521319182
# （必填参数）Gemini Enterprise 数据区域 (如 global, us, eu)
GE_APP_LOCATION="global"  # e.g., global, us, eu


# --- 本地运行配置 ---
# （选填）是否使用 Vertex AI (1) 或 Google AI Studio (0)
GOOGLE_GENAI_USE_VERTEXAI=0
# （选填）Google API Key (仅在 GOOGLE_GENAI_USE_VERTEXAI=0 时需要)
GOOGLE_API_KEY="your-api-key"